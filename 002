def mod_inverse(a, m=26):
    a = a % m
    for x in range(1, m):
        if (a * x) % m == 1:
            return x
    return -1


def encrypt(text, a, b):
    result = ""
    for ch in text:
        if ch.isalpha():
            ch = ch.upper()
            x = ord(ch) - ord('A')
            enc = (a * x + b) % 26
            result += chr(enc + ord('A'))
        else:
            result += ch
    return result


def decrypt(cipher, a, b):
    result = ""
    a_inv = mod_inverse(a)
    if a_inv == -1:
        return "Invalid key 'a'. No modular inverse."
    for ch in cipher:
        if ch.isalpha():
            ch = ch.upper()
            y = ord(ch) - ord('A')
            dec = (a_inv * (y - b + 26)) % 26
            result += chr(dec + ord('A'))
        else:
            result += ch
    return result

