# ── key helpers ──────────────────────────────
def is_prime(n):
    if n < 2: return False
    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0: return False
    return True

def mod_inverse(e, phi):
    for d in range(2, phi):
        if (d * e) % phi == 1:
            return d

# ── rsa core ─────────────────────────────────
def encrypt(private_key, plaintext):
    key, n = private_key
    return [pow(ord(c), key, n) for c in plaintext]

def decrypt(public_key, ciphertext):
    key, n = public_key
    return ''.join([chr(pow(c, key, n)) for c in ciphertext])

# ── hash + verify ─────────────────────────────
def hash_message(message):
    return sha256(message.encode("UTF-8")).hexdigest()

def verify(decrypted_hash, original_message):
    fresh = hash_message(original_message)
    print(f"\n  Received : {decrypted_hash}")
    print(f"  Expected : {fresh}")
    if decrypted_hash == fresh:
        print("  ✅ Verification SUCCESSFUL")
    else:
        print("  ❌ Verification FAILED")

