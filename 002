def key_scheduling(key):
    s = list(range(256))
    j = 0
    for i in range(256):
        j = (j + s[i] + key[i % len(key)]) % 256
        s[i], s[j] = s[j], s[i]
    return s

def stream_generation(s):
    i, j = 0, 0
    while True:
        i = (i + 1) % 256
        j = (j + s[i]) % 256
        s[i], s[j] = s[j], s[i]
        yield s[(s[i] + s[j]) % 256]

def encrypt(text, key):
    text_bytes = [ord(c) for c in text]
    key_bytes = [ord(c) for c in key]
    s = key_scheduling(key_bytes)
    key_stream = stream_generation(s)
    ciphertext = ""
    for byte in text_bytes:
        ciphertext += format(byte ^ next(key_stream), '02X')
    return ciphertext

def decrypt(ciphertext, key):
    cipher_bytes = [int(ciphertext[i:i+2], 16) for i in range(0, len(ciphertext), 2)]
    key_bytes = [ord(c) for c in key]
    s = key_scheduling(key_bytes)
    key_stream = stream_generation(s)
    plaintext = ""
    for byte in cipher_bytes:
        plaintext += chr(byte ^ next(key_stream))
    return plaintext

if __name__ == '__main__':
    choice = input("Enter E to encrypt or D to decrypt: ").upper()
