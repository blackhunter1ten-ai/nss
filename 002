def power(base, exp, mod):
    return pow(base, exp, mod)

def get_prime():
    while True:
        P = int(input("Enter a prime number P: "))
        is_prime = P > 1 and all(P % i != 0 for i in range(2, int(P**0.5) + 1))
        if is_prime:
            return P
        print("Not a prime, try again.")

def get_generator(P):
    while True:
        G = int(input(f"Enter generator G (between 1 and {P}): "))
        if 1 < G < P:
            return G
        print("Invalid generator, try again.")

def get_private_key(P):
    while True:
        key = int(input(f"Enter private key (between 1 and {P}): "))
        if 1 < key < P:
            return key
        print("Invalid key, try again.")

def diffie_hellman():
    P = get_prime()
    G = get_generator(P)
    print(f"P = {P}, G = {G}")

    key1 = get_private_key(P)
    key2 = get_private_key(P)

    pub1 = power(G, key1, P)
    pub2 = power(G, key2, P)
    print(f"Public key 1: {pub1}")
    print(f"Public key 2: {pub2}")

    secret1 = power(pub2, key1, P)
    secret2 = power(pub1, key2, P)
    print(f"Secret 1: {secret1}")
    print(f"Secret 2: {secret2}")

    if secret1 == secret2:
        print(f"Shared secret key = {secret1}")
    else:
        print("Keys don't match.")

if __name__ == "__main__":
    diffie_hellman()
