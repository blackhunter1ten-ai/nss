def encrypt(text, rails):
    fence = [""] * rails
    row, step = 0, 1

    for ch in text:
        fence[row] += ch

        if row == 0:
            step = 1
        elif row == rails - 1:
            step = -1

        row += step

    return "".join(fence)

def decrypt(cipher, rails):
    n = len(cipher)
    
    # Step 1: create pattern (which row each char belongs to)
    pattern = [0] * n
    row, step = 0, 1

    for i in range(n):
        pattern[i] = row

        if row == 0:
            step = 1
        elif row == rails - 1:
            step = -1

        row += step

    # Step 2: fill characters back
    result = [""] * n
    index = 0

    for r in range(rails):
        for i in range(n):
            if pattern[i] == r:
                result[i] = cipher[index]
                index += 1

    return "".join(result)


