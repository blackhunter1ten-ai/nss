import hashlib   # Python's built-in cryptographic hashing library

def sha1(message):
    # Step 1: create a SHA-1 hash object
    hasher = hashlib.sha1()

    # Step 2: feed the message into the hasher (must be bytes)
    hasher.update(message.encode('utf-8'))

    # Step 3: return the final hash as a hex string
    return hasher.hexdigest()

