def ksa(key: str):
    """Key-Scheduling Algorithm (KSA)"""
    key_bytes = [ord(c) for c in key]
    S = list(range(256))
    j = 0
    for i in range(256):
        j = (j + S[i] + key_bytes[i % len(key_bytes)]) % 256
        S[i], S[j] = S[j], S[i]  # swap
    return S

def prga(S, text: str):
    """Pseudo-Random Generation Algorithm (PRGA)"""
    i = 0
    j = 0
    result = []
    for char in text:
        i = (i + 1) % 256
        j = (j + S[i]) % 256
        S[i], S[j] = S[j], S[i]
        t = (S[i] + S[j]) % 256
        k = S[t]  # keystream byte
        result.append(chr(ord(char) ^ k))  # XOR with keystream
    return "".join(result)

def rc4(key: str, text: str) -> str:
    """RC4 encryption/decryption"""
    S = ksa(key)
    return prga(S, text)

